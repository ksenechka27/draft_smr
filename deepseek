function uniqueSorted(arr) {
  return [...new Set(arr)].sort((a, b) => a.localeCompare(b, 'ru'));
}
function getSections() { return uniqueSorted(rawData.map(i => i.s)); }
function getSubsections(section) { return uniqueSorted(rawData.filter(i => i.s === section).map(i => i.ss)); }
function getDetails(section, subsection) { return uniqueSorted(rawData.filter(i => i.s === section && i.ss === subsection).map(i => i.d)); }
function getSolutions(section, subsection, detail) { return rawData.filter(i => i.s === section && i.ss === subsection && i.d === detail); }

function clearChildren(el) { while (el.firstChild) el.removeChild(el.firstChild); }

function escapeHtml(str) {
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
function escapeRe(str) {
  return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}
function highlight(rawText, query) {
  const safe = escapeHtml(String(rawText || ''));
  if (!query) return safe;
  return safe.replace(new RegExp('(' + escapeRe(escapeHtml(query)) + ')', 'gi'), '<mark>$1</mark>');
}

function appendMultiline(container, text) {
  const lines = String(text || '').split('\n');
  lines.forEach((line, idx) => {
    container.appendChild(document.createTextNode(line));
    if (idx < lines.length - 1) container.appendChild(document.createElement('br'));
  });
}

// ─── ХЛЕБНЫЕ КРОШКИ ──────────────────────────────────────────────────
function crumb(parts, actions) {
  const html = parts.map((p, i) => {
    const isLink = actions && actions[i];
    if (isLink) {
      return `<span class="crumb-link" data-action="${actions[i]}">${escapeHtml(p)}</span>`;
    }
    return `<span>${escapeHtml(p)}</span>`;
  }).join('<span class="sep"> / </span>');
  els.crumbs.innerHTML = html;
  els.crumbs.querySelectorAll('[data-action]').forEach(el => {
    el.onclick = () => {
      const action = el.dataset.action;
      if (action === 'home') resetAll();
      else if (action === 'sections') renderSections();
      else if (action === 'subsections') renderSubsections();
      else if (action === 'zones') renderZones();
      else if (action === 'zone-subsections') renderZoneSubsections();
      else if (action === 'zone-details') renderZoneDetails();
      else if (action === 'glossary') goToGlossaryPage();
      else if (action === 'apps') goToAppsPage();
      else if (action === 'versions') goToVersionsPage();
    };
  });
}

// ─── НАВИГАЦИЯ ПО РАЗДЕЛАМ ──────────────────────────────────────────
function goToSectionsNav() { renderSections(); }

function renderSections() {
  setView('sections');
  crumb(['Главная', 'Разделы'], ['home', 'sections']);
  clearChildren(els.sectionsGrid);
  getSections().forEach(sec => {
    const btn = document.createElement('button');
    btn.className = 'card-btn';
    btn.textContent = sec;
    btn.onclick = () => selectSection(sec);
    els.sectionsGrid.appendChild(btn);
  });
}

function selectSection(section) {
  state.section = section;
  state.subsection = null;
  renderSubsections();
}

function renderSubsections() {
  setView('subsections');
  crumb(['Главная', 'Разделы', state.section], ['home', 'sections', 'subsections']);
  clearChildren(els.subsectionsGrid);
  getSubsections(state.section).forEach(ss => {
    const btn = document.createElement('button');
    btn.className = 'card-btn';
    btn.textContent = ss;
    btn.onclick = () => selectSubsection(ss);
    els.subsectionsGrid.appendChild(btn);
  });
}

function selectSubsection(subsection) {
  state.subsection = subsection;
  renderDetails();
}

function renderDetails() {
  setView('details');
  crumb(['Главная', 'Разделы', state.section, state.subsection], ['home', 'sections', 'subsections', 'details']);
  showToolbar('toolbar');
  clearChildren(els.detailsList);
  const details = getDetails(state.section, state.subsection);
  if (details.length === 0) {
    const empty = document.createElement('div');
    empty.className = 'no-results';
    empty.textContent = 'Нет данных для отображения';
    els.detailsList.appendChild(empty);
  } else {
    details.forEach(det => {
      els.detailsList.appendChild(buildDetailItem(state.section, state.subsection, det));
    });
  }
}

// ─── НАВИГАЦИЯ ПО ЗОНАМ ─────────────────────────────────────────────
function goToZonesNav() { renderZones(); }

function getAllZones() {
  const cnt = {};
  rawData.forEach(r => {
    (r.zone || '').split(',').forEach(z => {
      z = z.trim();
      if (z) cnt[z] = (cnt[z] || 0) + 1;
    });
  });
  return Object.entries(cnt).sort((a,b) => b[1]-a[1]);
}

function getZoneSubsections(zone) {
  const set = new Set();
  rawData.filter(r => inZone(r, zone)).forEach(r => set.add(r.ss));
  return [...set].filter(Boolean).sort();
}

function getZoneDetails(zone, ss) {
  const seen = new Set(), res = [];
  rawData.filter(r => inZone(r, zone) && r.ss === ss).forEach(r => {
    if (!seen.has(r.d)) { seen.add(r.d); res.push(r.d); }
  });
  return res;
}

function getZoneSolutions(zone, ss, d) {
  return rawData.filter(r => inZone(r, zone) && r.ss === ss && r.d === d);
}

function inZone(rec, zone) {
  return (rec.zone || '').split(',').map(z => z.trim()).includes(zone);
}

function renderZones() {
  setView('zones');
  crumb(['Главная', 'Зоны применения'], ['home', 'zones']);
  clearChildren(els.zonesGrid);
  getAllZones().forEach(([zone, cnt]) => {
    const btn = document.createElement('button');
    btn.className = 'card-btn zone-card';
    btn.innerHTML = `<span>${escapeHtml(zone)}</span><span class="zone-count">${cnt}</span>`;
    btn.onclick = () => { state.zone = zone; renderZoneSubsections(); };
    els.zonesGrid.appendChild(btn);
  });
}

function renderZoneSubsections() {
  setView('zoneSubsections');
  crumb(['Главная', 'Зоны применения', state.zone], ['home', 'zones', 'zone-subsections']);
  document.getElementById('zone-title').textContent = state.zone;
  clearChildren(els.zoneSubsectionsGrid);
  getZoneSubsections(state.zone).forEach(ss => {
    const btn = document.createElement('button');
    btn.className = 'card-btn';
    btn.textContent = ss;
    btn.onclick = () => { state.zone_ss = ss; renderZoneDetails(); };
    els.zoneSubsectionsGrid.appendChild(btn);
  });
}

function renderZoneDetails() {
  setView('zoneDetails');
  crumb(['Главная', 'Зоны применения', state.zone, state.zone_ss], ['home', 'zones', 'zone-subsections', 'zone-details']);
  document.getElementById('zone-ss-title').textContent = state.zone_ss;
  clearChildren(els.zoneDetailsGrid);
  getZoneDetails(state.zone, state.zone_ss).forEach(d => {
    const sols = getZoneSolutions(state.zone, state.zone_ss, d);
    const btn = document.createElement('button');
    btn.className = 'card-btn detail-card';
    const title = document.createElement('span');
    title.textContent = d;
    btn.appendChild(title);
    if (sols.length) {
      const badge = document.createElement('span');
      badge.className = 'zone-count';
      badge.textContent = sols.length + (sols.length === 1 ? ' решение' : sols.length < 5 ? ' решения' : ' решений');
      btn.appendChild(badge);
    }
    btn.onclick = () => { state.zone_d = d; renderZoneSolutions(); };
    els.zoneDetailsGrid.appendChild(btn);
  });
}

function renderZoneSolutions() {
  setView('zoneSolutions');
  crumb(['Главная', 'Зоны применения', state.zone, state.zone_ss, state.zone_d], ['home', 'zones', 'zone-subsections', 'zone-details', 'zone-solutions']);
  document.getElementById('zone-detail-title').textContent = state.zone_d;
  clearChildren(els.zoneSolutionsList);
  const sols = getZoneSolutions(state.zone, state.zone_ss, state.zone_d);
  sols.forEach(item => {
    const wrapper = document.createElement('details');
    wrapper.className = 'item';
    const summary = document.createElement('summary');
    const titleRow = document.createElement('div');
    titleRow.className = 'summary-title-row';
    titleRow.textContent = item.ss + ' / ' + item.d;
    summary.appendChild(titleRow);
    wrapper.appendChild(summary);
    const body = document.createElement('div');
    body.className = 'body';
    body.appendChild(buildSolutionBlock(item, null));
    wrapper.appendChild(body);
    els.zoneSolutionsList.appendChild(wrapper);
  });
}

// ─── ПОСТРОЕНИЕ БЛОКОВ ──────────────────────────────────────────────
function buildSolutionBlock(item, query) {
  const wrap = document.createElement('div');
  wrap.className = 'solution';
  const textEl = document.createElement('div');
  if (query) {
    textEl.innerHTML = highlight(item.sol, query).replace(/\n/g, '<br>');
  } else {
    appendMultiline(textEl, item.sol);
  }
  wrap.appendChild(textEl);
  const tags = document.createElement('div');
  tags.className = 'tags';
  if (item.app) {
    const t = document.createElement('span');
    t.className = 'tag';
    t.textContent = 'Приложение: ' + item.app.replace(/\n/g, ' ');
    tags.appendChild(t);
  }
  if (item.zone) {
    const t = document.createElement('span');
    t.className = 'tag';
    t.textContent = 'Зона: ' + item.zone;
    tags.appendChild(t);
  }
  if (tags.childNodes.length) wrap.appendChild(tags);
  return wrap;
}

function buildDetailItem(section, subsection, detail) {
  const solutions = getSolutions(section, subsection, detail);
  const details = document.createElement('details');
  details.className = 'item';
  const summary = document.createElement('summary');
  const titleRow = document.createElement('div');
  titleRow.className = 'summary-title-row';
  titleRow.appendChild(document.createTextNode(detail));
  summary.appendChild(titleRow);
  const firstSol = solutions[0];
  if (firstSol && firstSol.zone) {
    const zonesDiv = document.createElement('div');
    zonesDiv.className = 'zones';
    firstSol.zone.split(',').map(z => z.trim()).filter(Boolean).forEach(z => {
      const tag = document.createElement('span');
      tag.className = 'zone-tag';
      tag.textContent = z;
      zonesDiv.appendChild(tag);
    });
    summary.appendChild(zonesDiv);
  }
  details.appendChild(summary);
  const body = document.createElement('div');
  body.className = 'body';
  if (solutions.length === 0) {
    const empty = document.createElement('p');
    empty.className = 'empty';
    empty.textContent = 'Техническое решение отсутствует или не описано.';
    body.appendChild(empty);
  } else {
    solutions.forEach(sol => body.appendChild(buildSolutionBlock(sol, null)));
  }
  details.appendChild(body);
  return details;
}

// ─── ОБЩИЕ ФУНКЦИИ ──────────────────────────────────────────────────
function setView(view) {
  els.hubView.hidden = view !== 'hub';
  els.sectionsView.hidden = view !== 'sections';
  els.subsectionsView.hidden = view !== 'subsections';
  els.detailsView.hidden = view !== 'details';
  els.searchResultsView.hidden = view !== 'search';
  els.glossaryPageView.hidden = view !== 'glossaryPage';
  els.appsPageView.hidden = view !== 'appsPage';
  els.versionsPageView.hidden = view !== 'versionsPage';
  els.zonesView.hidden = view !== 'zones';
  els.zoneSubsectionsView.hidden = view !== 'zoneSubsections';
  els.zoneDetailsView.hidden = view !== 'zoneDetails';
  els.zoneSolutionsView.hidden = view !== 'zoneSolutions';
}

function showToolbar(id) {
  document.querySelectorAll('.toolbar').forEach(t => t.classList.remove('visible'));
  const el = document.getElementById(id);
  if (el) el.classList.add('visible');
}

function expandAll() { document.querySelectorAll('details.item').forEach(d => d.open = true); }
function collapseAll() { document.querySelectorAll('details.item').forEach(d => d.open = false); }
function doPrint() { expandAll(); setTimeout(() => window.print(), 120); }

function goToGlossaryPage() {
  setView('glossaryPage');
  crumb(['Главная', 'Основные понятия'], ['home', 'glossary']);
}
function goToAppsPage() {
  setView('appsPage');
  crumb(['Главная', 'Приложения'], ['home', 'apps']);
}
function goToVersionsPage() {
  setView('versionsPage');
  crumb(['Главная', 'Версификация'], ['home', 'versions']);
}
function resetAll() {
  state.section = null; state.subsection = null;
  state.zone = null; state.zone_ss = null; state.zone_d = null;
  els.searchInput.value = '';
  setView('hub');
  crumb(['Главная'], ['home']);
}

function renderSearchResults(query) {
  setView('search');
  showToolbar('toolbar-search');
  crumb(['Главная', 'Результаты поиска'], ['home', 'search']);
  clearChildren(els.searchResultsList);
  const q = query.trim().toLowerCase();
  const zoneVal = document.getElementById('zone-select').value;
  const matches = rawData.filter(i => {
    const textMatch = (i.s + ' ' + i.ss + ' ' + i.d + ' ' + i.sol + ' ' + (i.zone || '')).toLowerCase().includes(q);
    const zoneMatch = !zoneVal || (i.zone || '').split(',').map(z => z.trim()).includes(zoneVal);
    return textMatch && zoneMatch;
  });
  if (matches.length === 0) {
    const empty = document.createElement('div');
    empty.className = 'no-results';
    empty.textContent = 'Ничего не найдено по запросу «' + query + '»';
    els.searchResultsList.appendChild(empty);
    return;
  }
  matches.slice(0, 100).forEach(item => {
    const details = document.createElement('details');
    details.className = 'item';
    const summary = document.createElement('summary');
    const titleRow = document.createElement('div');
    titleRow.className = 'summary-title-row';
    titleRow.innerHTML = highlight(item.s, q) + ' / ' + highlight(item.ss, q) + ' / ' + highlight(item.d, q);
    summary.appendChild(titleRow);
    if (item.zone) {
      const zonesDiv = document.createElement('div');
      zonesDiv.className = 'zones';
      item.zone.split(',').map(z => z.trim()).filter(Boolean).forEach(z => {
        const tag = document.createElement('span');
        tag.className = 'zone-tag';
        tag.textContent = z;
        zonesDiv.appendChild(tag);
      });
      summary.appendChild(zonesDiv);
    }
    details.appendChild(summary);
    const body = document.createElement('div');
    body.className = 'body';
    body.appendChild(buildSolutionBlock(item, q));
    details.appendChild(body);
    els.searchResultsList.appendChild(details);
  });
}

// ─── КНОПКИ НАЗАД ────────────────────────────────────────────────────
document.getElementById('back-to-hub-from-sections').onclick = resetAll;
document.getElementById('back-to-sections').onclick = renderSections;
document.getElementById('back-to-subsections').onclick = renderSubsections;
document.getElementById('back-to-hub-from-glossary').onclick = resetAll;
document.getElementById('back-to-hub-from-apps').onclick = resetAll;
document.getElementById('back-to-hub-from-versions').onclick = resetAll;
document.getElementById('back-to-hub-from-zones').onclick = resetAll;
document.getElementById('back-to-zones').onclick = renderZones;
document.getElementById('back-to-zone-subsections').onclick = renderZoneSubsections;
document.getElementById('back-to-zone-details').onclick = renderZoneDetails;
document.getElementById('reset-btn').onclick = resetAll;

// ─── ПОИСК ────────────────────────────────────────────────────────────
let searchTimer = null;
els.searchInput.addEventListener('input', (e) => {
  clearTimeout(searchTimer);
  const value = e.target.value;
  searchTimer = setTimeout(() => {
    if (value.trim().length === 0) {
      resetAll();
    } else {
      renderSearchResults(value);
    }
  }, 200);
});

// ─── ЗАПОЛНЕНИЕ ВЫПАДАЮЩЕГО СПИСКА ЗОН ─────────────────────────────
(function initZoneSelect() {
  const sel = document.getElementById('zone-select');
  const zones = [...new Set(
    rawData.flatMap(i => (i.zone || '').split(',').map(z => z.trim()).filter(Boolean))
  )].sort((a, b) => a.localeCompare(b, 'ru'));
  zones.forEach(z => {
    const opt = document.createElement('option');
    opt.value = z; opt.textContent = z;
    sel.appendChild(opt);
  });
  sel.addEventListener('change', () => {
    const q = els.searchInput.value.trim();
    if (q.length > 0 || sel.value) {
      renderSearchResults(q || ' ');
    } else {
      renderSections();
    }
  });
})();

// ─── ТЕМА (светлая/тёмная) ──────────────────────────────────────────
function toggleTheme() {
  const html = document.documentElement;
  const current = html.getAttribute('data-theme');
  const next = current === 'light' ? '' : 'light';
  html.setAttribute('data-theme', next || '');
  const icon = document.getElementById('themeIcon');
  const label = document.getElementById('themeLabel');
  if (next === 'light') {
    icon.textContent = '☀️';
    label.textContent = 'Светлая';
  } else {
    icon.textContent = '🌙';
    label.textContent = 'Тёмная';
  }
  try { localStorage.setItem('smr_theme', next || 'dark'); } catch(e) {}
}

// Восстановить тему
(function loadTheme() {
  try {
    const saved = localStorage.getItem('smr_theme');
    if (saved === 'light') {
      document.documentElement.setAttribute('data-theme', 'light');
      document.getElementById('themeIcon').textContent = '☀️';
      document.getElementById('themeLabel').textContent = 'Светлая';
    }
  } catch(e) {}
})();

// ─── TITLE SCREEN ────────────────────────────────────────────────────
function closeTitleScreen() {
  document.getElementById('title-screen').classList.add('hidden');
  try { sessionStorage.setItem('smr_title_seen', '1'); } catch(e) {}
}
document.addEventListener('DOMContentLoaded', () => {
  let seen = false;
  try { seen = sessionStorage.getItem('smr_title_seen') === '1'; } catch(e) {}
  if (seen) document.getElementById('title-screen').classList.add('hidden');
});

// ─── ПРИЛОЖЕНИЯ ──────────────────────────────────────────────────────
function onAppClick(btn) {
  const url = btn.dataset.url;
  if (url) window.open(url, '_blank', 'noopener');
}

// ─── СТАРТ ────────────────────────────────────────────────────────────
renderSections();
</script>

