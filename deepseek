<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Стандарт СМР ММ 3.1</title>
<style>
  /* ═══════════════════════════════════════════════════════════════════
     ТЁМНАЯ ТЕМА (по умолчанию)  
  ═══════════════════════════════════════════════════════════════════ */
  :root {
    --bg-primary: #1a1a2e;
    --bg-secondary: #16213e;
    --bg-tertiary: #0f3460;
    --bg-surface: #1e1e32;
    --bg-surface-2: #2a2a42;
    --bg-surface-3: #3a3a5a;
    --text-primary: #ffffff;
    --text-secondary: #e0e0e0;
    --text-muted: #a0a0a0;
    --accent-color: #4a90d9;
    --accent-hover: #357abd;
    --border-color: #2d3748;
    --border-2: #3d4a5c;
    --red: #c0200e;
    --red-hover: #a01a0a;
    --red-muted: #2a1a1a;
    --red-border: #5a2a22;
    --card-shadow: 0 4px 12px rgba(0,0,0,0.5);
    --hover-bg: rgba(74, 144, 217, 0.08);
    --input-bg: #1e1e32;
  }

  /* ═══════════════════════════════════════════════════════════════════
     СВЕТЛАЯ ТЕМА  
  ═══════════════════════════════════════════════════════════════════ */
  [data-theme="light"] {
    --bg-primary: #f0f4f8;
    --bg-secondary: #ffffff;
    --bg-tertiary: #edf2f7;
    --bg-surface: #ffffff;
    --bg-surface-2: #f7fafc;
    --bg-surface-3: #e2e8f0;
    --text-primary: #1a202c;
    --text-secondary: #2d3748;
    --text-muted: #718096;
    --accent-color: #2563eb;
    --accent-hover: #1d4ed8;
    --border-color: #e2e8f0;
    --border-2: #cbd5e0;
    --red: #c0200e;
    --red-hover: #a01a0a;
    --red-muted: #fef2f2;
    --red-border: #fca5a5;
    --card-shadow: 0 4px 12px rgba(0,0,0,0.06);
    --hover-bg: rgba(37, 99, 235, 0.06);
    --input-bg: #ffffff;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    background: var(--bg-primary);
    color: var(--text-primary);
    line-height: 1.55;
    transition: background 0.2s, color 0.2s;
  }

  /* ── Scrollbar ── */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg-primary); }
  ::-webkit-scrollbar-thumb { background: var(--bg-surface-3); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--red); }

  /* ── Переключатель темы (фиксирован) ── */
  .theme-switcher {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 1000;
  }
  .theme-btn {
    background: var(--bg-surface);
    border: 2px solid var(--border-color);
    color: var(--text-primary);
    padding: 10px 16px;
    border-radius: 30px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 600;
    transition: all 0.2s ease;
    box-shadow: var(--card-shadow);
  }
  .theme-btn:hover { border-color: var(--red); }
  .theme-btn .icon { font-size: 18px; }

  /* ── Header ── */
  header {
    background: var(--bg-surface);
    border-bottom: 2px solid var(--red);
    padding: 0 20px;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 20px rgba(0,0,0,0.5);
  }
  .header-row {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 60px;
  }
  .header-brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .header-icon {
    width: 34px; height: 34px;
    background: var(--red);
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .header-icon svg { width: 18px; height: 18px; stroke: #fff; fill: none; }
  header .title {
    font-size: 15px;
    font-weight: 700;
    margin: 0;
    letter-spacing: .01em;
    color: var(--text-primary);
  }
  header .subtitle {
    font-size: 11px;
    color: var(--text-muted);
    margin: 0;
    letter-spacing: .04em;
    text-transform: uppercase;
  }
  #reset-btn {
    background: none;
    border: 1px solid var(--border-2);
    color: var(--text-muted);
    font-size: 12px;
    font-family: inherit;
    cursor: pointer;
    padding: 5px 14px;
    border-radius: 5px;
    transition: border-color .15s, color .15s;
  }
  #reset-btn:hover { border-color: var(--red); color: var(--red); }

  /* ── Breadcrumbs ── */
  nav.crumbs {
    max-width: 1100px;
    margin: 0 auto;
    padding: 8px 20px 0;
    font-size: 13px;
    color: var(--text-muted);
  }
  nav.crumbs .crumb-link {
    color: var(--red);
    cursor: pointer;
    font-weight: 500;
  }
  nav.crumbs .crumb-link:hover { text-decoration: underline; }
  nav.crumbs .sep { margin: 0 6px; color: var(--text-muted); }

  /* ── Main ── */
  main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 16px 20px 80px;
  }

  /* ── Intro ── */
  .intro {
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-left: 3px solid var(--red);
    border-radius: 6px;
    padding: 14px 18px;
    margin-bottom: 16px;
  }
  .intro h2 {
    margin: 0 0 3px;
    font-size: 16px;
    font-weight: 700;
    color: var(--text-primary);
  }
  .intro p { margin: 0; color: var(--text-muted); font-size: 13px; }

  /* ── Grid ── */
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  @media (max-width: 600px) { .grid { grid-template-columns: 1fr; } }

  /* ── Card buttons ── */
  .card-btn {
    display: block;
    width: 100%;
    text-align: left;
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-left: 3px solid transparent;
    border-radius: 6px;
    padding: 14px 16px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    cursor: pointer;
    font-family: inherit;
    transition: border-color .15s, background .15s, box-shadow .15s;
    line-height: 1.4;
    box-shadow: var(--card-shadow);
  }
  .card-btn:hover {
    border-color: var(--border-2);
    border-left-color: var(--red);
    background: var(--bg-surface-2);
  }

  .back-link {
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 13px;
    font-family: inherit;
    cursor: pointer;
    padding: 0;
    margin-bottom: 12px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: color .15s;
  }
  .back-link:hover { color: var(--red); }

  /* ── Accordion ── */
  details.item {
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    margin-bottom: 8px;
    overflow: hidden;
  }
  details.item:hover { border-color: var(--border-2); }
  details.item[open] { border-color: var(--red-border); }
  details.item[open] summary { border-bottom: 1px solid var(--border-color); }

  details.item summary {
    list-style: none;
    cursor: pointer;
    padding: 13px 16px;
    font-weight: 600;
    font-size: 14px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    color: var(--text-primary);
    user-select: none;
    transition: background .12s;
  }
  details.item summary:hover { background: var(--bg-surface-2); }
  details.item summary::-webkit-details-marker { display: none; }

  details.item summary .summary-title-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
  }
  details.item summary .summary-title-row::after {
    content: "+";
    color: var(--red);
    font-size: 20px;
    font-weight: 300;
    line-height: 1;
    flex-shrink: 0;
  }
  details.item[open] summary .summary-title-row::after { content: "–"; }

  details.item .body {
    padding: 0 16px 16px;
  }

  .solution {
    padding-top: 14px;
    font-size: 13px;
    color: var(--text-primary);
    line-height: 1.6;
  }
  .solution + .solution {
    border-top: 1px dashed var(--border-2);
    margin-top: 14px;
  }

  .tags { margin-top: 10px; display: flex; flex-wrap: wrap; gap: 5px; }
  .tag {
    font-size: 11px;
    color: var(--text-muted);
    background: var(--bg-surface-2);
    border: 1px solid var(--border-2);
    border-radius: 4px;
    padding: 3px 8px;
  }

  .zone-tag {
    display: inline-block;
    font-size: 11px; font-weight: 500;
    color: #e87070;
    background: var(--red-muted);
    border: 1px solid var(--red-border);
    border-radius: 10px;
    padding: 1px 7px;
    margin-left: 6px;
    white-space: nowrap;
  }
  details.item summary .zones {
    display: flex; flex-wrap: wrap; gap: 4px;
    margin-top: 5px;
  }

  .empty { color: var(--text-muted); font-style: italic; padding: 14px 16px; font-size: 13px; }
  .no-results { text-align: center; color: var(--text-muted); padding: 40px 20px; font-size: 14px; }

  /* ── Search ── */
  .search-box { margin-bottom: 14px; }
  .search-row { display: flex; gap: 8px; flex-wrap: wrap; }
  .search-row input { flex: 1; min-width: 200px; }

  .search-box input {
    width: 100%;
    padding: 10px 14px;
    font-size: 14px;
    font-family: inherit;
    background: var(--input-bg);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    color: var(--text-primary);
    outline: none;
    transition: border-color .15s;
  }
  .search-box input::placeholder { color: var(--text-muted); }
  .search-box input:focus { border-color: var(--red); box-shadow: 0 0 0 2px var(--red-muted); }

  .zone-select {
    padding: 9px 10px;
    font-size: 13px;
    font-family: inherit;
    background: var(--input-bg);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    color: var(--text-primary);
    min-width: 190px; max-width: 260px;
    cursor: pointer;
    outline: none;
  }
  .zone-select:focus { border-color: var(--red); }
  .zone-select option { background: var(--bg-surface-2); }

  /* ── Toolbar ── */
  .toolbar {
    display: none;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .toolbar.visible { display: flex; }
  .toolbar button {
    background: var(--bg-surface-2);
    border: 1px solid var(--border-2);
    border-radius: 5px;
    padding: 6px 13px;
    font-size: 12px;
    font-family: inherit;
    cursor: pointer;
    color: var(--text-muted);
    transition: border-color .15s, color .15s, background .15s;
  }
  .toolbar button:hover {
    background: var(--bg-surface-3);
    border-color: var(--border-2);
    color: var(--text-primary);
  }
  .btn-print {
    margin-left: auto;
    background: var(--red) !important;
    color: #fff !important;
    border-color: var(--red) !important;
    font-weight: 600;
  }
  .btn-print:hover { background: var(--red-hover) !important; }

  mark {
    background: #7a2a00;
    color: #ffb580;
    border-radius: 2px;
    padding: 0 2px;
    font-style: normal;
  }
  [data-theme="light"] mark {
    background: #fef08a;
    color: #1a202c;
  }

  /* ── Hub cards ── */
  .hub-card {
    display: flex !important;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 30px 16px !important;
    text-align: center !important;
    min-height: 120px;
  }
  .hub-card-icon {
    width: 44px; height: 44px;
    background: var(--red-muted);
    border: 1px solid var(--red-border);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
  }
  .hub-card-icon svg {
    width: 22px; height: 22px;
    stroke: #e87070; fill: none;
    stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;
  }
  .hub-card span:last-child { font-size: 14px; font-weight: 700; }

  /* ── Zone cards ── */
  .zone-card {
    display: flex !important;
    align-items: center !important;
    gap: 10px;
    padding: 14px 16px !important;
    min-height: unset;
    text-align: left !important;
    flex-direction: row !important;
    font-size: 13px !important;
    font-weight: 600;
  }
  .zone-card .zone-count {
    margin-left: auto;
    flex-shrink: 0;
    font-size: 11px;
    color: var(--text-muted);
    font-weight: 400;
    background: var(--bg-surface-2);
    border: 1px solid var(--border-2);
    border-radius: 20px;
    padding: 2px 8px;
  }

  .detail-card {
    display: flex !important;
    align-items: flex-start !important;
    gap: 10px;
    padding: 14px 16px !important;
    min-height: unset;
    text-align: left !important;
    flex-direction: column !important;
    font-size: 13px !important;
    font-weight: 600;
  }
  .detail-card .detail-zone-row {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 4px;
  }

  /* ── Title screen ── */
  #title-screen {
    position: fixed; inset: 0; z-index: 10000;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(180deg, rgba(14,14,14,.55), rgba(14,14,14,.92)),
                url('https://raw.githubusercontent.com/ksenechka27/smr_new/main/pic/title-bg.jpg')
                center/cover no-repeat, var(--bg-primary);
    text-align: center;
    transition: opacity .35s ease, visibility .35s ease;
  }
  #title-screen.hidden { opacity: 0; visibility: hidden; pointer-events: none; }
  #title-screen .ts-inner { max-width: 560px; padding: 0 24px; }
  #title-screen .ts-icon {
    width: 64px; height: 64px; margin: 0 auto 22px;
    background: var(--red); border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 8px 30px rgba(192,32,14,.4);
  }
  #title-screen .ts-icon svg { width: 32px; height: 32px; stroke: #fff; fill: none; }
  #title-screen h1 {
    font-size: 26px; font-weight: 800; color: #fff; margin: 0 0 6px;
    letter-spacing: .01em; line-height: 1.25;
  }
  #title-screen p.ts-sub {
    color: rgba(255,255,255,.55); font-size: 14px; margin: 0 0 26px;
    letter-spacing: .03em; text-transform: uppercase;
  }
  #title-screen .ts-version {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.14);
    border-radius: 30px; padding: 7px 18px; margin-bottom: 30px;
    color: #fff; font-size: 13px;
  }
  #title-screen .ts-version b { color: #ff8a6a; font-weight: 700; }
  #title-screen .ts-enter {
    background: var(--red); color: #fff; border: none;
    border-radius: 8px; padding: 13px 36px; font-family: inherit;
    font-size: 15px; font-weight: 700; cursor: pointer;
    letter-spacing: .02em; transition: background .15s, transform .1s;
  }
  #title-screen .ts-enter:hover { background: var(--red-hover); }
  #title-screen .ts-enter:active { transform: scale(.97); }
  #title-screen .ts-footer {
    margin-top: 22px; font-size: 11px; color: rgba(255,255,255,.35);
    letter-spacing: .04em; text-transform: uppercase;
  }

  /* ── Glossary ── */
  .glossary-flow { font-size: 13px; line-height: 1.85; color: var(--text-primary); }
  .glossary-flow b { color: #e87070; font-weight: 700; }

  /* ── Apps ── */
  .apps-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .app-btn {
    background: var(--bg-surface-2);
    border: 1px solid var(--border-2);
    border-radius: 5px;
    color: var(--text-primary);
    font-family: inherit;
    font-size: 12px;
    padding: 6px 11px;
    cursor: pointer;
    text-align: left;
    line-height: 1.3;
    transition: border-color .15s, color .15s, background .15s;
  }
  .app-btn:hover {
    border-color: var(--red-border);
    color: #e87070;
    background: var(--red-muted);
  }

  /* ── Version table ── */
  .version-table-wrap { max-height: 460px; overflow-y: auto; border: 1px solid var(--border-color); border-radius: 6px; }
  .version-table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
  .version-table th {
    text-align: left; padding: 8px 10px; color: var(--text-muted);
    font-weight: 600; border-bottom: 1px solid var(--border-2);
    white-space: nowrap; position: sticky; top: 0; background: var(--bg-surface);
  }
  .version-table td {
    padding: 9px 10px; border-bottom: 1px solid var(--border-color);
    vertical-align: top; color: var(--text-primary);
  }
  .version-table tr:hover td { background: var(--bg-surface-2); }
  .version-table .v-num { font-weight: 700; color: #e87070; white-space: nowrap; }
  .version-table .v-date { color: var(--text-muted); white-space: nowrap; }
  .version-table .v-changes { white-space: pre-line; max-width: 480px; font-size: 12px; line-height: 1.55; }
  .v-current-badge {
    display: inline-block; background: var(--red-muted); color: #e87070;
    border: 1px solid var(--red-border); border-radius: 4px;
    font-size: 10px; padding: 1px 6px; margin-left: 6px; font-weight: 600;
  }

  /* ── Lightbox ── */
  #lightbox {
    display:none; position:fixed; inset:0;
    background:rgba(0,0,0,.88); z-index:9999;
    align-items:center; justify-content:center; cursor:zoom-out;
  }
  #lightbox.open { display:flex; }
  #lightbox img { max-width:92vw; max-height:92vh; border-radius:8px; object-fit:contain; box-shadow:0 8px 40px rgba(0,0,0,.7); }
  #lb-close { position:fixed; top:16px; right:20px; background:none; border:none; color:#fff; font-size:32px; cursor:pointer; opacity:.7; }
  #lb-close:hover { opacity:1; }
  #lb-counter { position:fixed; bottom:20px; left:50%; transform:translateX(-50%); color:rgba(255,255,255,.6); font-size:13px; }

  /* ── Навигация: две кнопки выбора ── */
  .nav-choice-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  @media (max-width: 600px) { .nav-choice-grid { grid-template-columns: 1fr; } }
  .nav-choice-btn {
    display: flex !important;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    padding: 32px 16px !important;
    text-align: center !important;
    min-height: 130px;
  }
  .nav-choice-btn .icon {
    width: 48px; height: 48px;
    background: var(--red-muted);
    border: 1px solid var(--red-border);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
  }
  .nav-choice-btn .icon svg {
    width: 24px; height: 24px;
    stroke: #e87070; fill: none;
    stroke-width: 1.8;
  }
  .nav-choice-btn .label { font-size: 15px; font-weight: 700; }

  /* ── Print ── */
  @media print {
    header, nav.crumbs, #search-view, .toolbar,
    .back-link, #reset-btn, #view-sections, #view-subsections,
    #view-search-results, .theme-switcher, #title-screen { display: none !important; }
    body { background: #fff !important; color: #111 !important; }
    details.item { break-inside: avoid; border: 1px solid #ccc !important; }
    details.item .body { display: block !important; }
  }
</style>
</head>
<body>

<!-- ─── Переключатель темы ─── -->
<div class="theme-switcher">
  <button class="theme-btn" id="themeToggle" onclick="toggleTheme()">
    <span class="icon" id="themeIcon">🌙</span>
    <span id="themeLabel">Тёмная</span>
  </button>
</div>

<!-- ─── Title Screen ─── -->
<div id="title-screen">
  <div class="ts-inner">
    <div class="ts-icon">
      <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
    </div>
    <h1>Стандарт строительства, реконструкции и ремонта</h1>
    <p class="ts-sub">Магазинов формата ММ 3.1</p>
    <div class="ts-version">Текущая версия <b>3.12</b> · обновлено 26.05.2026</div>
    <div><button class="ts-enter" onclick="closeTitleScreen()">Открыть стандарт</button></div>
    <p class="ts-footer">АО «Тандер»</p>
  </div>
</div>

<!-- ─── Header ─── -->
<header>
  <div class="header-row">
    <div class="header-brand">
